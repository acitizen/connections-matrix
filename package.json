{
  "name": "creating-connections-cf",
  "version": "2.0.0",
  "description": "Creating Connections — Cloudflare Workers + D1 edition",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create creating-connections-db",
    "db:migrate": "wrangler d1 execute creating-connections-db --file=migrations/0001_schema.sql",
    "db:migrate:local": "wrangler d1 execute creating-connections-db --local --file=migrations/0001_schema.sql"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  }
}
